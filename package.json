{
  "name": "road",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["frontend", "backend"],
  "scripts": {
    "dev": "npm run dev:frontend & npm run dev:backend",
    "dev:frontend": "npm -w frontend run dev",
    "dev:backend": "npm -w backend run dev",
    "build": "npm -w frontend run build && npm -w backend run build",
    "build:frontend": "npm -w frontend run build",
    "build:backend": "npm -w backend run build",
    "lint": "npm -w frontend run lint && npm -w backend run lint",
    "prisma:generate": "npm -w backend run prisma:generate",
    "prisma:migrate": "npm -w backend run prisma:migrate",
    "prisma:studio": "npm -w backend run prisma:studio"
  }
}
